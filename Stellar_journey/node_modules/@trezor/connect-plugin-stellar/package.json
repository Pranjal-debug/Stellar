{
  "name": "@trezor/connect-plugin-stellar",
  "version": "10.0.0-alpha.1",
  "type": "module",
  "author": "Trezor <info@trezor.io>",
  "homepage": "https://github.com/trezor/trezor-suite/tree/develop/packages/connect-plugin-stellar",
  "description": "@trezor/connect plugin for Stellar",
  "license": "SEE LICENSE IN LICENSE.md",
  "repository": {
    "type": "git",
    "url": "git://github.com/trezor/trezor-suite.git"
  },
  "bugs": {
    "url": "https://github.com/trezor/trezor-suite/issues"
  },
  "keywords": [
    "Trezor",
    "trezor-connect",
    "stellar"
  ],
  "sideEffects": false,
  "main": "./libESM/index.mjs",
  "publishConfig": {
    "main": "./libESM/index.mjs",
    "types": "./libESM/index.d.mts",
    "exports": {
      ".": {
        "types": "./libESM/index.d.mts",
        "default": "./libESM/index.mjs"
      }
    }
  },
  "files": [
    "libESM/",
    "CHANGELOG.md"
  ],
  "peerDependencies": {
    "@stellar/stellar-sdk": "^13.3.0",
    "@trezor/connect": "9.x.x",
    "tslib": "^2.6.2"
  },
  "devDependencies": {
    "@stellar/stellar-sdk": "14.5.0",
    "@trezor/eslint": "1.0.0"
  },
  "dependencies": {
    "@trezor/utils": "10.0.0-alpha.1"
  },
  "scripts": {
    "test:unit": "yarn g:jest",
    "type-check": "yarn g:tsc --build tsconfig.json",
    "build:lib": "yarn g:rimraf ./libESM && yarn g:tsc --build tsconfig.libESM.json && ../../scripts/publish/replace-imports.sh ./libESM esm",
    "depcheck": "yarn g:depcheck",
    "lint:js": "yarn g:eslint '**/*.{ts,tsx,js}'"
  },
  "exports": {
    ".": {
      "types": "./libESM/index.d.mts",
      "default": "./libESM/index.mjs"
    }
  },
  "types": "./libESM/index.d.mts"
}