{
  "name": "@trezor/connect-common",
  "version": "10.0.0-alpha.1",
  "type": "module",
  "author": "Trezor <info@trezor.io>",
  "homepage": "https://github.com/trezor/trezor-suite/tree/develop/packages/connect-common",
  "keywords": [
    "Trezor",
    "trezor-connect"
  ],
  "repository": {
    "type": "git",
    "url": "git://github.com/trezor/trezor-suite.git"
  },
  "bugs": {
    "url": "https://github.com/trezor/trezor-suite/issues"
  },
  "license": "MIT",
  "description": "Collection of assets and utils used by trezor-connect library.",
  "main": "./libESM/index.mjs",
  "files": [
    "libESM/",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "main": "./libESM/index.mjs",
    "types": "./libESM/index.d.mts",
    "exports": {
      ".": {
        "types": "./libESM/index.d.mts",
        "default": "./libESM/index.mjs"
      },
      "./libESM/*": "./libESM/*",
      "./libESM/constants": {
        "types": "./libESM/constants/index.d.mts",
        "default": "./libESM/constants/index.mjs"
      },
      "./libESM/data": {
        "types": "./libESM/data/index.d.mts",
        "default": "./libESM/data/index.mjs"
      },
      "./libESM/events": {
        "types": "./libESM/events/index.d.mts",
        "default": "./libESM/events/index.mjs"
      },
      "./libESM/types": {
        "types": "./libESM/types/index.d.mts",
        "default": "./libESM/types/index.mjs"
      }
    }
  },
  "scripts": {
    "build:lib": "yarn g:rimraf ./libESM && yarn g:tsc --build tsconfig.libESM.json && ../../scripts/publish/replace-imports.sh ./libESM esm && DTS_OUT_DIR=libESM yarn build:dts:inline",
    "build:dts:inline": "node ../../scripts/inline-devdep-types.mjs",
    "type-check": "yarn g:tsc --build tsconfig.json",
    "test:unit": "yarn g:jest",
    "depcheck": "yarn g:depcheck",
    "lint:js": "yarn g:eslint '**/*.{ts,tsx,js}'"
  },
  "dependencies": {
    "@trezor/device-utils": "10.0.0-alpha.1",
    "@trezor/protobuf": "10.0.0-alpha.1",
    "@trezor/protocol": "^10.0.0-alpha.1",
    "@trezor/schema-utils": "10.0.0-alpha.1",
    "@trezor/type-utils": "10.0.0-alpha.1",
    "@trezor/utils": "10.0.0-alpha.1"
  },
  "peerDependencies": {
    "tslib": "^2.6.2"
  },
  "devDependencies": {
    "@fivebinaries/coin-selection": "3.0.0",
    "@trezor/blockchain-link": "^10.0.0-alpha.1",
    "@trezor/blockchain-link-types": "^10.0.0-alpha.1",
    "@trezor/device-authenticity": "^10.0.0-alpha.1",
    "@trezor/transport": "10.0.0-alpha.1",
    "@trezor/utxo-lib": "10.0.0-alpha.1",
    "@types/chrome": "^0.1.40",
    "@types/jest": "29.5.12",
    "@types/node": "22.13.10"
  },
  "exports": {
    ".": {
      "types": "./libESM/index.d.mts",
      "default": "./libESM/index.mjs"
    },
    "./libESM/*": "./libESM/*",
    "./libESM/constants": {
      "types": "./libESM/constants/index.d.mts",
      "default": "./libESM/constants/index.mjs"
    },
    "./libESM/data": {
      "types": "./libESM/data/index.d.mts",
      "default": "./libESM/data/index.mjs"
    },
    "./libESM/events": {
      "types": "./libESM/events/index.d.mts",
      "default": "./libESM/events/index.mjs"
    },
    "./libESM/types": {
      "types": "./libESM/types/index.d.mts",
      "default": "./libESM/types/index.mjs"
    }
  },
  "types": "./libESM/index.d.mts"
}