{
  "name": "@trezor/protobuf",
  "version": "10.0.0-alpha.1",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git://github.com/trezor/trezor-suite.git"
  },
  "bugs": {
    "url": "https://github.com/trezor/trezor-suite/issues"
  },
  "sideEffects": false,
  "main": "./libESM/index.mjs",
  "publishConfig": {
    "main": "./libESM/index.mjs",
    "types": "./libESM/index.d.mts",
    "exports": {
      ".": {
        "types": "./libESM/index.d.mts",
        "default": "./libESM/index.mjs"
      },
      "./libESM/*": "./libESM/*",
      "./libESM/definitions": {
        "types": "./libESM/definitions/index.d.mts",
        "default": "./libESM/definitions/index.mjs"
      },
      "./libESM/definitions/*": "./libESM/definitions/*"
    }
  },
  "files": [
    "libESM/",
    "CHANGELOG.md"
  ],
  "scripts": {
    "test:unit": "yarn g:jest",
    "depcheck": "yarn g:depcheck",
    "type-check": "yarn g:tsc --build",
    "build:lib": "yarn g:rimraf ./libESM && yarn g:tsc --build tsconfig.libESM.json && ../../scripts/publish/replace-imports.sh ./libESM esm",
    "update:protobuf": "./scripts/protobuf-build.sh",
    "lint:js": "yarn g:eslint '**/*.{ts,tsx,js}'"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.11.0",
    "@trezor/schema-utils": "10.0.0-alpha.1"
  },
  "devDependencies": {
    "@bufbuild/buf": "^1.67.0",
    "@bufbuild/protoc-gen-es": "2.11.0",
    "@bufbuild/protoplugin": "2.11.0",
    "@trezor/eslint": "1.0.0",
    "tsx": "^4.21.0"
  },
  "peerDependencies": {
    "tslib": "^2.6.2"
  },
  "exports": {
    ".": {
      "types": "./libESM/index.d.mts",
      "default": "./libESM/index.mjs"
    },
    "./libESM/*": "./libESM/*",
    "./libESM/definitions": {
      "types": "./libESM/definitions/index.d.mts",
      "default": "./libESM/definitions/index.mjs"
    },
    "./libESM/definitions/*": "./libESM/definitions/*"
  },
  "types": "./libESM/index.d.mts"
}