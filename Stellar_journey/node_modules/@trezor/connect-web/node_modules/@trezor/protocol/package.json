{
  "name": "@trezor/protocol",
  "version": "10.0.0-alpha.1",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git://github.com/trezor/trezor-suite.git"
  },
  "bugs": {
    "url": "https://github.com/trezor/trezor-suite/issues"
  },
  "sideEffects": false,
  "main": "./libESM/index.mjs",
  "publishConfig": {
    "main": "./libESM/index.mjs",
    "types": "./libESM/index.d.mts",
    "exports": {
      ".": {
        "types": "./libESM/index.d.mts",
        "default": "./libESM/index.mjs"
      },
      "./libESM/*": "./libESM/*",
      "./libESM/protocol-thp": {
        "types": "./libESM/protocol-thp/index.d.mts",
        "default": "./libESM/protocol-thp/index.mjs"
      },
      "./libESM/protocol-thp/messages": {
        "types": "./libESM/protocol-thp/messages/index.d.mts",
        "default": "./libESM/protocol-thp/messages/index.mjs"
      },
      "./libESM/protocol-tpn": {
        "types": "./libESM/protocol-tpn/index.d.mts",
        "default": "./libESM/protocol-tpn/index.mjs"
      }
    }
  },
  "files": [
    "libESM/",
    "CHANGELOG.md"
  ],
  "scripts": {
    "test:unit": "yarn g:jest",
    "depcheck": "yarn g:depcheck",
    "type-check": "yarn g:tsc --build",
    "build:lib": "yarn g:rimraf ./libESM && yarn g:tsc --build tsconfig.libESM.json && ../../scripts/publish/replace-imports.sh ./libESM esm",
    "lint:js": "yarn g:eslint '**/*.{ts,tsx,js}'"
  },
  "peerDependencies": {
    "tslib": "^2.6.2"
  },
  "exports": {
    ".": {
      "types": "./libESM/index.d.mts",
      "default": "./libESM/index.mjs"
    },
    "./libESM/*": "./libESM/*",
    "./libESM/protocol-thp": {
      "types": "./libESM/protocol-thp/index.d.mts",
      "default": "./libESM/protocol-thp/index.mjs"
    },
    "./libESM/protocol-thp/messages": {
      "types": "./libESM/protocol-thp/messages/index.d.mts",
      "default": "./libESM/protocol-thp/messages/index.mjs"
    },
    "./libESM/protocol-tpn": {
      "types": "./libESM/protocol-tpn/index.d.mts",
      "default": "./libESM/protocol-tpn/index.mjs"
    }
  },
  "types": "./libESM/index.d.mts"
}