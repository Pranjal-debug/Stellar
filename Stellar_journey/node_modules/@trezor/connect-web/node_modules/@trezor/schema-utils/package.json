{
  "name": "@trezor/schema-utils",
  "version": "10.0.0-alpha.1",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "main": "./libESM/index.mjs",
  "publishConfig": {
    "main": "./libESM/index.mjs",
    "types": "./libESM/index.d.mts",
    "exports": {
      ".": {
        "types": "./libESM/index.d.mts",
        "default": "./libESM/index.mjs"
      },
      "./libESM/custom-types/*": "./libESM/custom-types/*"
    }
  },
  "files": [
    "libESM/"
  ],
  "scripts": {
    "test:unit": "yarn g:jest",
    "depcheck": "yarn g:depcheck",
    "type-check": "yarn g:tsc --build",
    "build:lib": "yarn g:rimraf ./libESM && yarn g:tsc --build tsconfig.libESM.json && ../../scripts/publish/replace-imports.sh ./libESM esm",
    "codegen": "tsx ./src/codegen.ts",
    "lint:js": "yarn g:eslint '**/*.{ts,tsx,js}'"
  },
  "devDependencies": {
    "@sinclair/typebox-codegen": "^0.11.1",
    "@trezor/eslint": "1.0.0",
    "tsx": "^4.21.0"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.49",
    "@trezor/type-utils": "10.0.0-alpha.1",
    "ts-mixer": "^6.0.4"
  },
  "peerDependencies": {
    "tslib": "^2.6.2"
  },
  "exports": {
    ".": {
      "types": "./libESM/index.d.mts",
      "default": "./libESM/index.mjs"
    },
    "./libESM/custom-types/*": "./libESM/custom-types/*"
  },
  "types": "./libESM/index.d.mts"
}