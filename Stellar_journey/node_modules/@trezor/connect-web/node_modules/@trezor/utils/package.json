{
  "name": "@trezor/utils",
  "version": "10.0.0-alpha.1",
  "type": "module",
  "author": "Trezor <info@trezor.io>",
  "homepage": "https://github.com/trezor/trezor-suite/tree/develop/packages/utils",
  "description": "A collection of typescript utils that are intended to be used across trezor-suite monorepo.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git://github.com/trezor/trezor-suite.git"
  },
  "bugs": {
    "url": "https://github.com/trezor/trezor-suite/issues"
  },
  "sideEffects": false,
  "main": "./libESM/index.mjs",
  "publishConfig": {
    "main": "./libESM/index.mjs",
    "types": "./libESM/index.d.mts",
    "exports": {
      ".": {
        "types": "./libESM/index.d.mts",
        "default": "./libESM/index.mjs"
      },
      "./libESM/*": "./libESM/*"
    }
  },
  "files": [
    "libESM/",
    "CHANGELOG.md"
  ],
  "scripts": {
    "test:unit": "yarn g:jest",
    "type-check": "yarn g:tsc --build tsconfig.json",
    "build:lib": "yarn g:rimraf ./libESM && yarn g:tsc --build tsconfig.libESM.json && ../../scripts/publish/replace-imports.sh ./libESM esm",
    "depcheck": "yarn g:depcheck",
    "lint:js": "yarn g:eslint '**/*.{ts,tsx,js}'"
  },
  "peerDependencies": {
    "tslib": "^2.6.2"
  },
  "devDependencies": {
    "@trezor/eslint": "1.0.0",
    "@trezor/type-utils": "10.0.0-alpha.1"
  },
  "dependencies": {
    "bignumber.js": "^9.3.1"
  },
  "browser": {
    "crypto": false
  },
  "exports": {
    ".": {
      "types": "./libESM/index.d.mts",
      "default": "./libESM/index.mjs"
    },
    "./libESM/*": "./libESM/*"
  },
  "types": "./libESM/index.d.mts"
}