{
  "name": "@trezor/websocket-client",
  "version": "10.0.0-alpha.1",
  "type": "module",
  "author": "Trezor <info@trezor.io>",
  "homepage": "https://github.com/trezor/trezor-suite/tree/develop/packages/websocket",
  "description": "Shared websocket client implementation",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git://github.com/trezor/trezor-suite.git"
  },
  "bugs": {
    "url": "https://github.com/trezor/trezor-suite/issues"
  },
  "sideEffects": false,
  "main": "./libESM/index.mjs",
  "browser": {
    "ws": "./libESM/ws.browser.mjs"
  },
  "react-native": {
    "__comment__": "Hotfix for issue where RN metro bundler resolve relatives paths wrong",
    "ws": "@trezor/websocket-client/src/ws.native.ts"
  },
  "publishConfig": {
    "main": "./libESM/index.mjs",
    "types": "./libESM/index.d.mts",
    "exports": {
      ".": {
        "types": "./libESM/index.d.mts",
        "default": "./libESM/index.mjs"
      }
    },
    "browser": {
      "ws": "./libESM/ws.browser.mjs"
    },
    "react-native": {
      "__comment__": "Hotfix for issue where RN metro bundler resolve relatives paths wrong",
      "ws": "@trezor/websocket-client/libESM/ws.native.mjs"
    }
  },
  "files": [
    "libESM/",
    "CHANGELOG.md"
  ],
  "scripts": {
    "depcheck": "yarn g:depcheck",
    "test:unit": "yarn g:jest",
    "type-check": "yarn g:tsc --build",
    "build:lib": "yarn g:rimraf ./libESM && yarn g:tsc --build tsconfig.libESM.json && ../../scripts/publish/replace-imports.sh ./libESM esm",
    "lint:js": "yarn g:eslint '**/*.{ts,tsx,js}'"
  },
  "dependencies": {
    "@trezor/utils": "10.0.0-alpha.1",
    "ws": "^8.20.0"
  },
  "peerDependencies": {
    "tslib": "^2.6.2"
  },
  "devDependencies": {
    "@types/jest": "29.5.12",
    "@types/node": "22.13.10",
    "@types/web": "^0.0.345",
    "@types/ws": "^8.5.13"
  },
  "exports": {
    ".": {
      "types": "./libESM/index.d.mts",
      "default": "./libESM/index.mjs"
    }
  },
  "types": "./libESM/index.d.mts"
}