{
  "name": "@trezor/connect-web",
  "version": "10.0.0-alpha.1",
  "type": "module",
  "author": "Trezor <info@trezor.io>",
  "homepage": "https://github.com/trezor/trezor-suite/tree/develop/packages/connect-web",
  "description": "High-level javascript interface for Trezor hardware wallet in web environment.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git://github.com/trezor/trezor-suite.git"
  },
  "bugs": {
    "url": "https://github.com/trezor/trezor-suite/issues"
  },
  "keywords": [
    "Trezor",
    "trezor-connect",
    "javascript"
  ],
  "sideEffects": false,
  "main": "./libESM/index.mjs",
  "publishConfig": {
    "main": "./libESM/index.mjs",
    "types": "./libESM/index.d.mts",
    "exports": {
      ".": {
        "types": "./libESM/index.d.mts",
        "default": "./libESM/index.mjs"
      },
      "./libESM/impl/*": "./libESM/impl/*"
    }
  },
  "files": [
    "libESM/",
    "CHANGELOG.md"
  ],
  "scripts": {
    "depcheck": "yarn g:depcheck",
    "test:unit": "yarn g:jest",
    "type-check": "yarn g:tsc --build",
    "build:lib": "yarn g:rimraf ./libESM && yarn g:tsc --build tsconfig.libESM.json && ../../scripts/publish/replace-imports.sh ./libESM esm && DTS_OUT_DIR=libESM yarn build:dts:inline",
    "build:dts:inline": "node ../../scripts/inline-devdep-types.mjs",
    "test:e2e": "yarn playwright install && yarn xvfb-maybe -- playwright test --config=./e2e/playwright.config.ts",
    "lint:js": "yarn g:eslint '**/*.{ts,tsx,js}'"
  },
  "dependencies": {
    "@trezor/connect-common": "10.0.0-alpha.1",
    "@trezor/utils": "10.0.0-alpha.1",
    "@trezor/websocket-client": "10.0.0-alpha.1"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "@trezor/eslint": "1.0.0",
    "@trezor/type-utils": "10.0.0-alpha.1",
    "@types/chrome": "^0.1.40",
    "@types/jest": "29.5.12",
    "@types/w3c-web-usb": "^1.0.14",
    "@types/web": "^0.0.345",
    "xvfb-maybe": "^0.2.1"
  },
  "peerDependencies": {
    "tslib": "^2.6.2"
  },
  "exports": {
    ".": {
      "types": "./libESM/index.d.mts",
      "default": "./libESM/index.mjs"
    },
    "./libESM/impl/*": "./libESM/impl/*"
  },
  "types": "./libESM/index.d.mts"
}